---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import Layout from '@src/layouts/DocsLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('docs');
  return posts
    .filter(
      (post) =>
        // Filter out draft posts and _index pages
        post.data.draft !== true && !post.id.endsWith('/_index')
    )
    .map((post) => ({
      params: { slug: post.id },
      props: post,
    }));
}
type Props = CollectionEntry<'docs'>;

const post = Astro.props;
const { Content, headings } = await render(post);
---

<Layout post={post.data} headings={headings}>
  <Content />
</Layout>
